# =========================================================
# 🌐 Backend: API Configuration
# =========================================================

# Application environment (development | production | test)
NODE_ENV=development

# API server port
PORT=8080

# Maximum number of in-memory entries (leave empty for default)
MAX_MEMORY_ENTRIES=

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080


# =========================================================
# 🪵 Logging
# =========================================================

# Log level (debug | info | warn | error)
LOG_LEVEL=info


# =========================================================
# 🎨 Frontend Configuration
# =========================================================
SITE_URL=

# Public API URL (accessible from browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080/api/v1

# Internal API URL (used in Docker/network)
BACKEND_INTERNAL_URL=http://api:8080/api/v1

# Admin email (used for admin panel)
ADMIN_EMAIL=


# =========================================================
# 🗄 Backend: Database & Cache
# =========================================================

# Primary database connection string
DATABASE_URL=

# Redis connection
REDIS_URL=
REDIS_HOST=
REDIS_PORT=

# =========================================================
# 🔐 Security & Secrets
# =========================================================

# Secret used for authentication/session encryption
AUTH_SECRET=

# Base URL for auth callbacks
AUTH_BASE_URL=http://localhost:8080


# =========================================================
# 🔑 Authentication Sessions
# =========================================================

# Session lifetime in seconds
AUTH_SESSION_TTL_SECONDS=

# Reset session TTL on activity (true | false)
AUTH_SESSION_RESET_TTL_ON_USE=true

# Enable caching for sessions
AUTH_SESSION_CACHE_ENABLED=true

# Cache max age (seconds)
AUTH_SESSION_CACHE_MAX_AGE_SECONDS=

# OTP expiration time (seconds)
AUTH_OTP_TTL_SECONDS=

# Max OTP attempts
AUTH_OTP_ALLOWED_ATTEMPTS=3


# =========================================================
# 📧 Email Configuration
# =========================================================

# Email provider (e.g., smtp, resend, sendgrid)
AUTH_EMAIL_PROVIDER=

# Sender email address
AUTH_EMAIL_FROM=


# =========================================================
# 📬 SMTP Configuration (if using SMTP)
# =========================================================

AUTH_SMTP_HOST=
AUTH_SMTP_PORT=
AUTH_SMTP_SECURE= # true | false
AUTH_SMTP_USER=
AUTH_SMTP_PASS=


# =========================================================
# 🚦 Rate Limiting
# =========================================================

# Time window in ms
RATE_LIMIT_WINDOW_MS=

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=

# =========================================================
# AI Provider and Private Policy
# =========================================================

AI_API_KEY=
AI_BASE_URL=
AI_PRIVATE_CONFIG_PATH=
AI_PRIVATE_CONFIG_JSON=
AI_STANDARD_MODEL=
AI_EXPERT_MODEL=

# =========================================================
# Dodo Payments
# =========================================================

DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_PORTFOLIO_PRO_SEVEN_DAY_PRODUCT_ID=
DODO_PAYMENTS_PORTFOLIO_PRO_MONTHLY_PRODUCT_ID=
DODO_PAYMENTS_PORTFOLIO_PRO_ANNUAL_PRODUCT_ID=
DODO_PAYMENTS_BUNDLE_ONE_DAY_PRODUCT_ID=
DODO_PAYMENTS_BUNDLE_SEVEN_DAY_PRODUCT_ID=
DODO_PAYMENTS_AI_CREDITS_MONTHLY_PRODUCT_ID=
DODO_PAYMENTS_AI_CREDITS_ANNUAL_PRODUCT_ID=
DODO_PAYMENTS_BUNDLE_MONTHLY_PRODUCT_ID=
DODO_PAYMENTS_BUNDLE_ANNUAL_PRODUCT_ID=
DODO_PAYMENTS_CREDIT_PACK_100_PRODUCT_ID=


# =========================================================
# ⚡ Cache TTLs (in seconds)
# =========================================================

ROADMAP_CACHE_TTL_SECONDS=
ROADMAP_STATS_CACHE_TTL_SECONDS=
ROADMAP_TAGS_CACHE_TTL_SECONDS=
GITHUB_STATS_CACHE_TTL_SECONDS=


# =========================================================
# 🐙 GitHub Sync (Optional)
# =========================================================

# Enable GitHub sync
GITHUB_SYNC_ENABLED=false

# GitHub personal access token
GITHUB_TOKEN=

# Repository details
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_PROJECT_URL=

# Cron schedule (default: twice daily)
GITHUB_SYNC_CRON=0 0,12 * * *

# Timezone for cron jobs
GITHUB_SYNC_TIMEZONE=

# Internal API key for sync jobs
INTERNAL_SYNC_API_KEY=


# =========================================================
# 📊 Usage Metrics
# =========================================================

# Cron for flushing metrics
USAGE_METRICS_FLUSH_CRON=10 0 * * *

# Timezone for metrics job
USAGE_METRICS_FLUSH_TIMEZONE=
